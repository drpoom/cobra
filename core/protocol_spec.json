{
  "_meta": {
    "name": "COINES Protocol Specification",
    "version": "3.0.0",
    "description": "Single source of truth for COINES V3 protocol constants and BMM350 register map. All implementations (Python, JavaScript, etc.) must derive their constants from this file.",
    "license": "MIT",
    "author": "COBRA"
  },
  "packet": {
    "header": 170,
    "header_hex": "0xAA",
    "types": {
      "GET": 1,
      "SET": 2
    },
    "status": {
      "OK": 0
    }
  },
  "commands": {
