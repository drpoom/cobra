    "pin_direction": {
      "IN": 0,
      "OUT": 1
    },
    "pin_value": {
      "LOW": 0,
      "HIGH": 1
    }
  },
  "payload_formats": {
    "i2c_write": {
      "description": "I2C Write request payload",
      "fields": [
        {
          "offset": 0,
          "size": 1,
          "name": "dev_addr",
          "type": "uint8",
          "description": "7-bit I2C device address"
        },
        {
          "offset": 1,
          "size": 1,
          "name": "speed",
          "type": "uint8",
          "description": "I2C speed enum"
        },
        {
          "offset": 2,
          "size": 1,
          "name": "reg_addr",
          "type": "uint8",
          "description": "Register address"
        },
        {
          "offset": 3,
          "size": 1,
          "name": "data_len",
          "type": "uint8",
          "description": "Number of data bytes"
        },
        {
          "offset": 4,
          "size": "N",
          "name": "data",
          "type": "bytes",
          "description": "Data to write"
        }
      ]
    },
    "i2c_read": {
      "description": "I2C Read request payload",
      "fields": [
        {
          "offset": 0,
          "size": 1,
          "name": "dev_addr",
          "type": "uint8",
          "description": "7-bit I2C device address"
        },
        {
          "offset": 1,
          "size": 1,
          "name": "speed",
          "type": "uint8",
          "description": "I2C speed enum"
        },
        {
          "offset": 2,
          "size": 1,
          "name": "reg_addr",
          "type": "uint8",
          "description": "Register address to read"
        },
        {
          "offset": 3,
          "size": 1,
          "name": "length",
          "type": "uint8",
          "description": "Number of bytes to read"
        }
      ]
    },
    "spi_write": {
      "description": "SPI Write request payload",
      "fields": [
        {
          "offset": 0,
          "size": 1,
          "name": "cs",
          "type": "uint8",
          "description": "Chip-select line index"
        },
        {
          "offset": 1,
          "size": 1,
          "name": "speed",
          "type": "uint8",
          "description": "SPI speed enum"
        },
        {
          "offset": 2,
          "size": 1,
          "name": "mode",
          "type": "uint8",
          "description": "SPI mode (0 or 3)"
        },
        {
          "offset": 3,
          "size": 1,
          "name": "reg_addr",
          "type": "uint8",
          "description": "Register address"
        },
        {
          "offset": 4,
          "size": 1,
          "name": "data_len",
          "type": "uint8",
          "description": "Number of data bytes"
        },
        {
          "offset": 5,
          "size": "N",
          "name": "data",
          "type": "bytes",
          "description": "Data to write"
        }
      ]
    },
    "spi_read": {
      "description": "SPI Read request payload",
      "fields": [
        {
          "offset": 0,
          "size": 1,
          "name": "cs",
          "type": "uint8",
          "description": "Chip-select line index"
        },
        {
          "offset": 1,
          "size": 1,
          "name": "speed",
          "type": "uint8",
          "description": "SPI speed enum"
        },
        {
          "offset": 2,
          "size": 1,
          "name": "mode",
          "type": "uint8",
          "description": "SPI mode (0 or 3)"
        },
        {
          "offset": 3,
          "size": 1,
          "name": "reg_addr",
          "type": "uint8",
          "description": "Register address to read"
        },
        {
          "offset": 4,
          "size": 1,
          "name": "length",
          "type": "uint8",
          "description": "Number of bytes to read"
        }
      ]
    },
    "set_vdd": {
      "description": "Set VDD voltage",
      "fields": [
        {
          "offset": 0,
          "size": 2,
          "name": "voltage_mv",
          "type": "uint16_le",
          "description": "Voltage in millivolts (0=off)"
        }
      ]
    },
    "set_vddio": {
      "description": "Set VDDIO voltage",
      "fields": [
        {
          "offset": 0,
          "size": 2,
          "name": "voltage_mv",
          "type": "uint16_le",
          "description": "Voltage in millivolts (0=off)"
        }
      ]
    },
    "config_i2c_bus": {
      "description": "Configure I2C bus and speed",
      "fields": [
        {
          "offset": 0,
          "size": 1,
          "name": "bus",
          "type": "uint8",
          "description": "I2C bus number (0 or 1)"
        },
        {
          "offset": 1,
          "size": 1,
          "name": "speed",
          "type": "uint8",
          "description": "I2C speed mode (0=standard/400K, 1=fast/1M, 2=high/3.4M)"
        }
      ]
    },
    "config_spi_bus": {
      "description": "Configure SPI bus, mode, and speed",
      "fields": [
        {
          "offset": 0,
          "size": 1,
          "name": "bus",
          "type": "uint8",
          "description": "SPI bus number (0 or 1)"
        },
        {
          "offset": 1,
          "size": 1,
          "name": "mode",
          "type": "uint8",
          "description": "SPI mode (0 or 3)"
        },
        {
          "offset": 2,
          "size": 1,
          "name": "speed",
          "type": "uint8",
          "description": "SPI speed enum (0=5MHz, 1=10MHz)"
        }
      ]
    },
    "set_pin": {
      "description": "Configure a shuttle board pin",
      "fields": [
        {
          "offset": 0,
          "size": 1,
          "name": "pin",
          "type": "uint8",
          "description": "Shuttle board pin number (see shuttle_board.pins)"
        },
        {
          "offset": 1,
          "size": 1,
          "name": "direction",
          "type": "uint8",
          "description": "Pin direction (0=IN, 1=OUT)"
        },
        {
          "offset": 2,
          "size": 1,
          "name": "value",
          "type": "uint8",
          "description": "Pin value (0=LOW, 1=HIGH)"
        }
      ]
    }
  },
